{
  "mcpServers": {
    "memory": {
      "command": "node",
      "args": [
        "/home/prachwal/.npm-global/lib/node_modules/@modelcontextprotocol/server-memory/dist/index.js"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'find .claude/plans/archive/ -mtime +30 -type f -delete 2>/dev/null || true; find artifacts/coverage artifacts/docs -type f -delete 2>/dev/null || true'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm prettier --write \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "head -50"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; [[ \"$f\" != *pnpm-lock* && \"$f\" != */artifacts/* ]] || (echo \"BLOCKED: do not edit $f directly\" && exit 1)'"
          }
        ]
      }
    ]
  }
}
