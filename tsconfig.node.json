{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "composite": true,
    "outDir": ".tsbuild",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "eslint.config.ts"]
}
