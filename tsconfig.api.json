{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node", "hono"],
    "paths": {
      "@shared/*": ["./packages/shared/src/*"],
      "@shared": ["./packages/shared/src/index.ts"]
    }
  },
  "include": ["api", "packages/shared/src"]
}
